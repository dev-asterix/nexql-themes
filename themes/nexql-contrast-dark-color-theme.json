  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FF00CC"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#CC33FF"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Aliases and parameters",
      "scope": [
        "variable.parameter.sql",
        "variable.other.sql",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#FF9900"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#00FF66"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FF9900"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#CC33FF"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#CC33FF"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#FF9900"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00FF66"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#CC33FF"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#FF9900"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#CC33FF"
      }
    },
    {
      "name": "Preprocessor directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "JSDoc / TSDoc",
      "scope": [
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "keyword.operator.borrow.rust"
      ],
      "settings": {
        "foreground": "#00FF66"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#00CCFF"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF0055",
        "background": "#3A1828"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#00CCFF",
    "function": "#FF00CC",
    "method": "#FF00CC",
    "class": "#CC33FF",
    "type": "#CC33FF",
    "struct": "#CC33FF",
    "interface": "#CC33FF",
    "enum": "#CC33FF",
    "parameter": "#FFFFFF",
    "variable": "#FFFFFF",
    "property": "#FFFFFF",
    "string": "#FF9900",
    "number": "#00FF66",
    "comment": {
      "foreground": "#888888",
      "italic": true
    },
    "operator": "#00CCFF",
    "variable.declaration": "#FFFFFF",
    "function.declaration": {
      "foreground": "#FF00CC",
      "fontStyle": "bold"
    },
    "class.declaration": {
      "foreground": "#CC33FF",
      "fontStyle": "bold"
    },
    "variable.static": "#FFFFFF",
    "type.defaultLibrary": "#CC33FF",
    "function.defaultLibrary": "#FF00CC",
    "variable.defaultLibrary": "#FFFFFF",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.modification": "#FFFFFF",
    "label": "#00CCFF",
    "typeParameter": "#CC33FF",
    "regexp": "#FF9900",
    "event": "#FF00CC"
  }
}

  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7D6A5F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#DECBC0"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#D45A2A"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#DECBC0"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"
      ],
      "settings": {
        "foreground": "#BDAB9F"
      }
    },
    {
      "name": "Aliases and parameters",
      "scope": [
        "variable.parameter.sql",
        "variable.other.sql",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#BDAB9F"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#9FB88E"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#7D6A5F"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#9FB88E"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#9FB88E"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#E6A15C"
      }
    },
    {
      "name": "Preprocessor directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#DECBC0"
      }
    },
    {
      "name": "JSDoc / TSDoc",
      "scope": [
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#7D6A5F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#DECBC0"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#BDAB9F"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "keyword.operator.borrow.rust"
      ],
      "settings": {
        "foreground": "#E08F62"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#D45A2A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E05343",
        "background": "#3A1828"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#DECBC0",
    "function": "#D45A2A",
    "method": "#D45A2A",
    "class": "#E6A15C",
    "type": "#E6A15C",
    "struct": "#E6A15C",
    "interface": "#E6A15C",
    "enum": "#E6A15C",
    "parameter": "#BDAB9F",
    "variable": "#BDAB9F",
    "property": "#BDAB9F",
    "string": "#9FB88E",
    "number": "#E6A15C",
    "comment": {
      "foreground": "#7D6A5F",
      "italic": true
    },
    "operator": "#7D6A5F",
    "variable.declaration": "#BDAB9F",
    "function.declaration": {
      "foreground": "#D45A2A",
      "fontStyle": "bold"
    },
    "class.declaration": {
      "foreground": "#E6A15C",
      "fontStyle": "bold"
    },
    "variable.static": "#BDAB9F",
    "type.defaultLibrary": "#E6A15C",
    "function.defaultLibrary": "#D45A2A",
    "variable.defaultLibrary": "#BDAB9F",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.modification": "#BDAB9F",
    "label": "#DECBC0",
    "typeParameter": "#E6A15C",
    "regexp": "#9FB88E",
    "event": "#D45A2A"
  }
}

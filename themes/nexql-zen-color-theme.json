  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4F4F51",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#9E9E9F"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#9E9E9F"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9E9E9F"
      }
    },
    {
      "name": "Aliases and parameters",
      "scope": [
        "variable.parameter.sql",
        "variable.other.sql",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#4F4F51"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Preprocessor directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "JSDoc / TSDoc",
      "scope": [
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#4F4F51",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#9E9E9F"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "keyword.operator.borrow.rust"
      ],
      "settings": {
        "foreground": "#B8B8BA"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#838385"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#8F4F58",
        "background": "#3A1828"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#838385",
    "function": "#9E9E9F",
    "method": "#9E9E9F",
    "class": "#838385",
    "type": "#838385",
    "struct": "#838385",
    "interface": "#838385",
    "enum": "#838385",
    "parameter": "#838385",
    "variable": "#9E9E9F",
    "property": "#9E9E9F",
    "string": "#B8B8BA",
    "number": "#B8B8BA",
    "comment": {
      "foreground": "#4F4F51",
      "italic": true
    },
    "operator": "#4F4F51",
    "variable.declaration": "#9E9E9F",
    "function.declaration": {
      "foreground": "#9E9E9F",
      "fontStyle": "bold"
    },
    "class.declaration": {
      "foreground": "#838385",
      "fontStyle": "bold"
    },
    "variable.static": "#9E9E9F",
    "type.defaultLibrary": "#838385",
    "function.defaultLibrary": "#9E9E9F",
    "variable.defaultLibrary": "#9E9E9F",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.modification": "#9E9E9F",
    "label": "#838385",
    "typeParameter": "#838385",
    "regexp": "#B8B8BA",
    "event": "#9E9E9F"
  }
}

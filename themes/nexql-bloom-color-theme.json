  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A68996",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E91E63"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#AB47BC"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#7B1FA2"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#3D2B33"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"
      ],
      "settings": {
        "foreground": "#3D2B33"
      }
    },
    {
      "name": "Aliases and parameters",
      "scope": [
        "variable.parameter.sql",
        "variable.other.sql",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6E505E"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#689F38"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#F57C00"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#AB47BC"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#F57C00"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7B1FA2"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#7B1FA2"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#689F38"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#F57C00"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#7B1FA2"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#689F38"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7B1FA2"
      }
    },
    {
      "name": "Preprocessor directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#E91E63"
      }
    },
    {
      "name": "JSDoc / TSDoc",
      "scope": [
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#A68996",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#E91E63"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#3D2B33"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "keyword.operator.borrow.rust"
      ],
      "settings": {
        "foreground": "#F57C00"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#E91E63"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#D32F2F",
        "background": "#3A1828"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#E91E63",
    "function": "#AB47BC",
    "method": "#AB47BC",
    "class": "#7B1FA2",
    "type": "#7B1FA2",
    "struct": "#7B1FA2",
    "interface": "#7B1FA2",
    "enum": "#7B1FA2",
    "parameter": "#6E505E",
    "variable": "#3D2B33",
    "property": "#3D2B33",
    "string": "#689F38",
    "number": "#F57C00",
    "comment": {
      "foreground": "#A68996",
      "italic": true
    },
    "operator": "#AB47BC",
    "variable.declaration": "#3D2B33",
    "function.declaration": {
      "foreground": "#AB47BC",
      "fontStyle": "bold"
    },
    "class.declaration": {
      "foreground": "#7B1FA2",
      "fontStyle": "bold"
    },
    "variable.static": "#3D2B33",
    "type.defaultLibrary": "#7B1FA2",
    "function.defaultLibrary": "#AB47BC",
    "variable.defaultLibrary": "#3D2B33",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.modification": "#3D2B33",
    "label": "#E91E63",
    "typeParameter": "#7B1FA2",
    "regexp": "#689F38",
    "event": "#AB47BC"
  }
}

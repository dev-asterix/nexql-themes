  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#60607A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#26A69A"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#7E57C2"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#C0C0D8"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"

  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#60607A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL keywords",
      "scope": [
        "keyword",
        "keyword.other.sql",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.sql",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#26A69A"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.sql"
      ],
      "settings": {
        "foreground": "#7E57C2"
      }
    },
    {
      "name": "Tables",
      "scope": [
        "entity.name.table.sql",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#C0C0D8"
      }
    },
    {
      "name": "Columns and variables",
      "scope": [
        "variable",
        "variable.other",
        "meta.column.sql",
        "variable.other.column.sql",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9C9CB0"
      }
    },
    {
      "name": "Aliases and parameters",
      "scope": [
        "variable.parameter.sql",
        "variable.other.sql",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B0BEC5"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#D4E157"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#FF7043"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.sql",
        "punctuation"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FF7043"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7E57C2"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#7E57C2"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#FFCA28"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FF7043"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#26A69A"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#D4E157"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7E57C2"
      }
    },
    {
      "name": "Preprocessor directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "JSDoc / TSDoc",
      "scope": [
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#60607A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#9C9CB0"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust",
        "keyword.operator.borrow.rust"
      ],
      "settings": {
        "foreground": "#FF7043"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.self"
      ],
      "settings": {
        "foreground": "#5C6BC0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#EF5350",
        "background": "#3A1828"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#5C6BC0",
    "function": "#26A69A",
    "method": "#26A69A",
    "class": "#7E57C2",
    "type": "#7E57C2",
    "struct": "#7E57C2",
    "interface": "#7E57C2",
    "enum": "#7E57C2",
    "parameter": "#B0BEC5",
    "variable": "#9C9CB0",
    "property": "#9C9CB0",
    "string": "#D4E157",
    "number": "#FF7043",
    "comment": {
      "foreground": "#60607A",
      "italic": true
    },
    "operator": "#5C6BC0",
    "variable.declaration": "#9C9CB0",
    "function.declaration": {
      "foreground": "#26A69A",
      "fontStyle": "bold"
    },
    "class.declaration": {
      "foreground": "#7E57C2",
      "fontStyle": "bold"
    },
    "variable.static": "#9C9CB0",
    "type.defaultLibrary": "#7E57C2",
    "function.defaultLibrary": "#26A69A",
    "variable.defaultLibrary": "#9C9CB0",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.modification": "#9C9CB0",
    "label": "#5C6BC0",
    "typeParameter": "#7E57C2",
    "regexp": "#D4E157",
    "event": "#26A69A"
  }
}
